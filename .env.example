# Senha da base central PostgreSQL (Bloco A v4). Nunca commitar o valor real.
# Usada por cercas_v2.py (_pg_conectar) quando --pg-dsn não inclui password=.
CERCAS_DB_PASSWORD=

# DSN usada pelos testes de integração do Bloco A (test_cercas_pg_integration.py).
# Só é necessária para rodar esses testes; se ausente, eles são pulados (skip).
# A senha pode vir embutida aqui OU ser lida de CERCAS_DB_PASSWORD acima
# (se a DSN abaixo não tiver "password=", _pg_conectar() completa com ela).
CERCAS_TEST_PG_DSN=host=localhost port=5432 dbname=cercas_v4 user=cercas_app
